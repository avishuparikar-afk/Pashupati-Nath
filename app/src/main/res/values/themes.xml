<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PASHURAKSHA" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/ghibli_sage</item>
        <item name="colorPrimaryVariant">@color/ghibli_sage_deep</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ghibli_peach</item>
        <item name="colorSecondaryVariant">@color/ghibli_peach_deep</item>
        <item name="colorOnSecondary">@color/ink_primary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/ghibli_cream</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/ghibli_card</item>
        <item name="android:windowBackground">@color/ghibli_cream</item>
        <item name="android:textColorPrimary">@color/ink_primary</item>
        <item name="android:textColorSecondary">@color/ink_secondary</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Theme.PASHURAKSHA.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.PASHURAKSHA.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.PASHURAKSHA.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
