<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghibli_cream"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Greeting -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/greetingTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="नमस्ते किसान 🌾"
                    android:textColor="@color/ink_primary"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/villageNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sample Village ☁️"
                    android:textColor="@color/ink_secondary"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="🧑‍🌾"
                android:textSize="26sp"
                android:gravity="center"
                android:background="@drawable/avatar_bot" />
        </LinearLayout>

        <!-- Status chip + weather -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/pill_safe"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/riskChipText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Village is safe"
                    android:textColor="@color/ghibli_sage_deep"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/weatherTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="☀️  25°C"
                android:textColor="@color/ink_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:gravity="center_vertical" />
        </LinearLayout>

        <!-- Hero: Scan Animal (sage gradient) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnStartScan"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            android:foreground="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/card_sage"
                android:orientation="horizontal"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan Your Animal"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Take a photo and let AI check"
                        android:textColor="#F0FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins"
                        android:layout_marginTop="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/pill_safe"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷  Start Scan"
                            android:textColor="@color/ghibli_sage_deep"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="🐄"
                    android:textSize="80sp"
                    android:gravity="center" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stat mini cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_ghibli"
                android:padding="18dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱  Scanned Today"
                    android:textColor="@color/ink_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:id="@+id/statScannedToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/ghibli_sage_deep"
                    android:textSize="30sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_ghibli"
                android:padding="18dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️  Immunity"
                    android:textColor="@color/ink_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:id="@+id/statImmunityScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="82%"
                    android:textColor="@color/ghibli_peach_deep"
                    android:textSize="30sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What would you like to do?"
            android:textColor="@color/ink_primary"
            android:textSize="17sp"
            android:fontFamily="@font/poppins"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="28dp" />

        <!-- Action grid 2x2 - colorful Ghibli cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="12dp">

            <!-- Chatbot - peach -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnChatbot"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="3dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_peach"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬"
                        android:textSize="32sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ask Pashu Doctor"
                        android:textColor="@color/ink_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chat in Hindi"
                        android:textColor="#663A3628"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Immunity - sky -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnImmunityCalculator"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="3dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_sky"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️"
                        android:textSize="32sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Immunity"
                        android:textColor="@color/ink_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Herd strength"
                        android:textColor="#663A3628"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="12dp">

            <!-- Outbreak Map - rose -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnOutbreakMap"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="3dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_rose"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗺️"
                        android:textSize="32sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Outbreak Map"
                        android:textColor="@color/ink_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Village heatmap"
                        android:textColor="#663A3628"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Reports - cream -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnHealthReport"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="3dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_ghibli"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📖"
                        android:textSize="32sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reports"
                        android:textColor="@color/ink_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Past scans"
                        android:textColor="@color/ink_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Pashupatinath featured row -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnPashupatinathMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="3dp"
            android:foreground="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_ghibli"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔱"
                    android:textSize="42sp"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pashupatinath Mode"
                        android:textColor="@color/ghibli_peach_deep"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cosmic blessing for your herd"
                        android:textColor="@color/ink_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ink_secondary"
                    android:textSize="28sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
